# Application
APP_NAME=go-base-framework
APP_ENV=development
APP_VERSION=1.0.0
APP_LOG_LEVEL=info

# HTTP Server
HTTP_PORT=3000
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
HTTP_REQUEST_TIMEOUT=30s
HTTP_MAX_BODY_BYTES=10485760

# CORS (comma-separated; use * for development, explicit origins for production)
CORS_ALLOWED_ORIGINS=*

# Rate Limit (optional — wire ratelimit middleware in server.go to enable)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# SQLite Database
DB_PATH=./db/app.db

# Redis Cache
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s

# JWT
JWT_SECRET_KEY=your-secret-key-minimum-32-characters
JWT_ACCESS_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h
JWT_ISSUER=go-base-framework

# Bcrypt
BCRYPT_COST=12
